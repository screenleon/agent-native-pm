#!/usr/bin/env bash
# Pre-push hook: runs the backend test suite against SQLite before each push.
# Prevents CI failures caused by regressions that are detectable locally.
#
# Install once per clone:
#   git config core.hooksPath .githooks
#
# Skip (emergency use only):
#   git push --no-verify

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BACKEND="$ROOT/backend"

# Only run when backend files changed in the commits being pushed.
# Read remote and local refs from stdin (format: <local-ref> <local-sha> <remote-ref> <remote-sha>)
run_backend=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
  # remote_sha is all zeros when the remote branch does not yet exist
  if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
    # New branch: check all files in the push
    if git diff --name-only HEAD | grep -q "^backend/"; then
      run_backend=1
      break
    fi
    # Also check against the first commit on the branch
    if git diff --name-only "${local_sha}" 2>/dev/null | grep -q "^backend/"; then
      run_backend=1
      break
    fi
    # Fallback: always run for new branches
    run_backend=1
    break
  else
    if git diff --name-only "${remote_sha}..${local_sha}" | grep -q "^backend/"; then
      run_backend=1
      break
    fi
  fi
done

if [[ "$run_backend" -eq 0 ]]; then
  exit 0
fi

echo "[pre-push] backend files changed — running tests (SQLite, no Docker required)"
echo "[pre-push] to skip: git push --no-verify"

export TEST_DATABASE_URL="sqlite"
unset DATABASE_URL 2>/dev/null || true

cd "$BACKEND"
if ! go test ./... -count=1 -timeout 180s; then
  echo ""
  echo "[pre-push] BLOCKED: backend tests failed. Fix them before pushing."
  echo "[pre-push] to skip (emergency only): git push --no-verify"
  exit 1
fi

echo "[pre-push] all backend tests passed"
