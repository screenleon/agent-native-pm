/vendor/

# Node / Frontend
/frontend/node_modules/
/frontend/dist/

# Python (reference adapter byproducts)
__pycache__/
*.pyc

# SQLite
*.db
*.db-shm
*.db-wal

# Docker & Database
/data/

# Data directory (runtime)
/data/

